{
  "name": "Merlin",
  "version": "1.21.27",
  "description": "Merlin — Your AI CMO",
  "main": "app/main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.91",
    "dompurify": "^3.3.3",
    "kokoro-js": "^1.2.1",
    "marked": "^18.0.2",
    "qrcode": "^1.5.4",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "electron": "41.2.0",
    "electron-builder": "^26.8.1"
  },
  "//overrides": "REGRESSION GUARD (2026-05-09, npm-audit-fast-uri): fast-uri@3.1.0 (transitive via @anthropic-ai/claude-agent-sdk → @modelcontextprotocol/sdk → ajv) shipped two HIGH-severity advisories (GHSA-Q3J6-QGPJ-74H6, GHSA-V39H-62P7-JPJC) that broke v1.21.27's build-mac-installer + build-win-installer at the npm-audit gate. Patched in 3.1.2. Override forces every transitive copy to ^3.1.2 until the upstream chain (ajv → mcp-sdk → claude-agent-sdk) bumps naturally. Remove this override only AFTER confirming `npm ls fast-uri --omit=dev` shows >= 3.1.2 without it.",
  "overrides": {
    "fast-uri": "^3.1.2"
  },
  "build": {
    "appId": "com.merlin.desktop",
    "productName": "Merlin",
    "asar": true,
    "protocols": [
      {
        "name": "Merlin",
        "schemes": [
          "merlin"
        ]
      }
    ],
    "asarUnpack": [
      "node_modules/@anthropic-ai/claude-agent-sdk/**/*",
      "node_modules/onnxruntime-node/**/*",
      "node_modules/onnxruntime-common/**/*",
      "node_modules/kokoro-js/**/*",
      "node_modules/@huggingface/transformers/**/*",
      "node_modules/phonemizer/**/*",
      "app/merlin-mcp-shim.js"
    ],
    "afterSign": "build/notarize.js",
    "extraResources": [
      {
        "from": ".claude",
        "to": ".claude",
        "filter": [
          "**/*",
          "!tools/merlin-config.json",
          "!tools/.merlin-*"
        ]
      },
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*",
          "!brands/*",
          "brands/example/**/*",
          "!music/*.mp3",
          "!music/*.wav"
        ]
      },
      {
        "from": "CLAUDE.md",
        "to": "CLAUDE.md"
      },
      {
        "from": "memory.md",
        "to": "memory.md"
      },
      {
        "from": "version.json",
        "to": "version.json"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "app/icon-1024.png",
      "files": [
        "!.claude${/*}",
        "!assets${/*}",
        "!results${/*}",
        "!.merlin-*",
        "!test-sdk.js",
        "!README.txt",
        "!LICENSE.txt",
        "!CLAUDE.md",
        "!memory.md",
        "!app/preview-harness.html",
        "!app/preview-stub.js",
        "!app/*.test.js",
        "!app/*.test.mjs",
        "!test${/*}",
        "!node_modules/onnxruntime-node/bin/napi-v3/darwin${/*}",
        "!node_modules/onnxruntime-node/bin/napi-v3/linux${/*}"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "app/icon-1024.png",
      "files": [
        "!.claude${/*}",
        "!assets${/*}",
        "!results${/*}",
        "!.merlin-*",
        "!test-sdk.js",
        "!README.txt",
        "!LICENSE.txt",
        "!CLAUDE.md",
        "!memory.md",
        "!app/preview-harness.html",
        "!app/preview-stub.js",
        "!app/*.test.js",
        "!app/*.test.mjs",
        "!test${/*}",
        "!node_modules/onnxruntime-node/bin/napi-v3/win32${/*}",
        "!node_modules/onnxruntime-node/bin/napi-v3/linux${/*}"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Merlin uses your microphone for voice input — transcribing what you say into messages. Audio is processed locally on your device and never uploaded."
      }
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "include": "build/installer.nsh",
      "artifactName": "Merlin.Setup.${version}.${ext}",
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Merlin",
      "runAfterFinish": false,
      "menuCategory": false,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "app/icon.ico",
      "uninstallerIcon": "app/icon.ico",
      "installerHeaderIcon": "app/icon.ico"
    }
  }
}
