{
  "name": "Merlin",
  "version": "1.22.4",
  "description": "Merlin — Your AI CMO",
  "main": "app/main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.91",
    "dompurify": "^3.3.3",
    "kokoro-js": "^1.2.1",
    "marked": "^18.0.2",
    "qrcode": "^1.5.4",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "electron": "41.2.0",
    "electron-builder": "^26.8.1"
  },
  "//overrides": "REGRESSION GUARD (2026-05-13, npm-audit-protobufjs): protobufjs@7.5.5 (transitive via kokoro-js → @huggingface/transformers → onnxruntime-web) shipped four HIGH advisories (GHSA-66FF-XGX4-VCHM code injection through bytes field defaults, GHSA-75PX-5XX7-5XC7 code-gen gadget after prototype pollution, GHSA-JVWF-75H9-CWGG process-wide DoS via unsafe option paths, GHSA-685M-2W69-288Q DoS via unbounded recursion) that broke v1.22.3's build-mac/win-installer at the npm-audit gate. Latest 7.x patch is 7.5.8; latest overall is 8.2.1. Override forces every transitive copy to ^7.5.8 (safer than the 8.x major bump for onnxruntime-web compatibility — protobufjs 7→8 changed API surface). Remove this override ONLY after confirming `npm ls protobufjs --omit=dev` shows >= 7.5.8 (or 8.x consumer) without it. The earlier fast-uri override (2026-05-09, GHSA-Q3J6-QGPJ-74H6 + GHSA-V39H-62P7-JPJC, patched in 3.1.2, transitive via @anthropic-ai/claude-agent-sdk → mcp-sdk → ajv) follows the same shape and is retained until the upstream chain bumps naturally.",
  "overrides": {
    "fast-uri": "^3.1.2",
    "protobufjs": "^7.5.8"
  },
  "build": {
    "appId": "com.merlin.desktop",
    "productName": "Merlin",
    "asar": true,
    "protocols": [
      {
        "name": "Merlin",
        "schemes": [
          "merlin"
        ]
      }
    ],
    "asarUnpack": [
      "node_modules/@anthropic-ai/claude-agent-sdk/**/*",
      "node_modules/onnxruntime-node/**/*",
      "node_modules/onnxruntime-common/**/*",
      "node_modules/kokoro-js/**/*",
      "node_modules/@huggingface/transformers/**/*",
      "node_modules/phonemizer/**/*",
      "app/merlin-mcp-shim.js"
    ],
    "afterSign": "build/notarize.js",
    "extraResources": [
      {
        "from": ".claude",
        "to": ".claude",
        "filter": [
          "**/*",
          "!tools/merlin-config.json",
          "!tools/.merlin-*"
        ]
      },
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*",
          "!brands/*",
          "brands/example/**/*",
          "!music/*.mp3",
          "!music/*.wav"
        ]
      },
      {
        "from": "CLAUDE.md",
        "to": "CLAUDE.md"
      },
      {
        "from": "memory.md",
        "to": "memory.md"
      },
      {
        "from": "version.json",
        "to": "version.json"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "app/icon-1024.png",
      "files": [
        "!.claude${/*}",
        "!assets${/*}",
        "!results${/*}",
        "!.merlin-*",
        "!test-sdk.js",
        "!README.txt",
        "!LICENSE.txt",
        "!CLAUDE.md",
        "!memory.md",
        "!app/preview-harness.html",
        "!app/preview-stub.js",
        "!app/*.test.js",
        "!app/*.test.mjs",
        "!test${/*}",
        "!node_modules/onnxruntime-node/bin/napi-v3/darwin${/*}",
        "!node_modules/onnxruntime-node/bin/napi-v3/linux${/*}"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "app/icon-1024.png",
      "files": [
        "!.claude${/*}",
        "!assets${/*}",
        "!results${/*}",
        "!.merlin-*",
        "!test-sdk.js",
        "!README.txt",
        "!LICENSE.txt",
        "!CLAUDE.md",
        "!memory.md",
        "!app/preview-harness.html",
        "!app/preview-stub.js",
        "!app/*.test.js",
        "!app/*.test.mjs",
        "!test${/*}",
        "!node_modules/onnxruntime-node/bin/napi-v3/win32${/*}",
        "!node_modules/onnxruntime-node/bin/napi-v3/linux${/*}"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Merlin uses your microphone for voice input — transcribing what you say into messages. Audio is processed locally on your device and never uploaded."
      }
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "include": "build/installer.nsh",
      "artifactName": "Merlin.Setup.${version}.${ext}",
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Merlin",
      "runAfterFinish": false,
      "menuCategory": false,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "app/icon.ico",
      "uninstallerIcon": "app/icon.ico",
      "installerHeaderIcon": "app/icon.ico"
    }
  }
}
